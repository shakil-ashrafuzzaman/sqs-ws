---
import Card from '@components/common/Card.astro';
import Badge from '@components/common/Badge.astro';
import { sanityClient, urlFor } from '@lib/sanity';

const query = `*[_type == "certification"] | order(order asc) {
  name,
  shortName,
  description,
  verificationUrl,
  logo
}`;
const fetchedAccreditations = await sanityClient.fetch(query).catch(() => []);

const accreditations = fetchedAccreditations && fetchedAccreditations.length > 0 ? fetchedAccreditations : [];
---

<section class="section bg-light border-y border-border overflow-hidden">
  <div class="container flex flex-col gap-10">
    <div class="text-center max-w-3xl mx-auto flex flex-col items-center gap-4">
      <Badge variant="gold">Compliance & Certifications</Badge>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-navy">
        Industry-Leading <span class="text-gold-dark">Certifications</span>
      </h2>
      <p class="text-steel-dark text-lg leading-relaxed">
        SQS Security Service operates to the highest British Standards. We are rigorously audited by independent bodies to ensure our operational excellence, health & safety compliance, and data security are second to none.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {accreditations.map((acc: any) => (
        <a href={acc.verificationUrl || '#'} target="_blank" rel="noopener noreferrer" class="group h-full outline-none focus-visible:ring-2 focus-visible:ring-gold rounded-xl">
          <Card class="h-full bg-white flex flex-col gap-4 border-2 border-transparent group-hover:border-gold/30 transition-all duration-300 transform group-hover:-translate-y-1 group-focus-visible:-translate-y-1">
            <div class="flex items-center justify-between border-b border-border pb-4">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-lg flex items-center justify-center shrink-0 bg-navy/5 p-1 text-navy">
                  {acc.logo?.asset ? (
                     <img src={urlFor(acc.logo).width(100).height(100).url()} alt={acc.name} class="w-full h-full object-contain" />
                  ) : (
                     <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                  )}
                </div>
                <div class="flex flex-col">
                  <span class="text-[10px] uppercase font-bold text-steel tracking-wider">{acc.shortName}</span>
                  <h3 class="font-display font-bold text-lg text-navy leading-tight">{acc.name}</h3>
                </div>
              </div>
              <svg class="w-5 h-5 text-steel-light group-hover:text-gold-dark transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </div>
            <p class="text-steel-dark text-sm leading-relaxed mt-2">
              {acc.description}
            </p>
          </Card>
        </a>
      ))}
    </div>
  </div>
</section>
