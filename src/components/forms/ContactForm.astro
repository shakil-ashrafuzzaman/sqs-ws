---
import Button from '@components/common/Button.astro';
import { sanityClient } from '@lib/sanity';

const fetchedServices = await sanityClient.fetch(`*[_type == "service"] | order(order asc)[0...8] {
  title
}`).catch(() => []);

const fallbackServiceTitles = [
  'Security Guarding',
  'Waking Watch',
  'Construction Security',
  'Dog Handler / K9',
  'Warehouse Security',
  'Office Security',
  'Void Property',
  'Emergency Cover'
];

const serviceTitles = fetchedServices.length > 0 
  ? [...fetchedServices.map((s: any) => s.title), 'Other']
  : [...fallbackServiceTitles, 'Other'];

interface Props {
  class?: string;
}

const { class: className = "bg-white p-8 rounded-xl shadow-card border border-border w-full relative" } = Astro.props;
---

<div class={className}>
  <!-- Alerts Container -->
  <div id="form-alerts" class="mb-6 hidden flex-col gap-4">
    <!-- Success Alert -->
    <div id="alert-success" class="hidden bg-success/10 border border-success/20 text-success-dark p-4 rounded-lg items-start gap-3">
      <svg class="w-5 h-5 shrink-0 mt-0.5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <div class="flex flex-col">
        <span class="font-bold">Message Sent Successfully!</span>
        <span class="text-sm">Thank you for contacting SQS Security. We will be in touch shortly.</span>
      </div>
    </div>
    
    <!-- Error Alert -->
    <div id="alert-error" class="hidden bg-emergency/10 border border-emergency/20 text-emergency p-4 rounded-lg items-start gap-3">
      <svg class="w-5 h-5 shrink-0 mt-0.5 text-emergency" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
      <div class="flex flex-col">
        <span class="font-bold">Submission Failed</span>
        <span id="error-message" class="text-sm">Please check the form for errors and try again.</span>
      </div>
    </div>
  </div>

  <form id="contact-form" class="flex flex-col gap-4 md:gap-6" novalidate>
    <!-- Honeypot Field (Hidden from users, catches bots) -->
    <div class="hidden" aria-hidden="true">
      <label for="website">Website</label>
      <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
      <div class="flex flex-col gap-2">
        <label for="name" class="text-sm font-semibold text-navy">Full Name <span class="text-emergency">*</span></label>
        <input type="text" id="name" name="name" required class="w-full px-4 py-2.5 rounded-lg bg-light border border-border focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent transition-shadow text-sm text-text" placeholder="John Doe" />
        <span class="error-msg text-xs text-emergency hidden" data-for="name"></span>
      </div>
      
      <div class="flex flex-col gap-2">
        <label for="email" class="text-sm font-semibold text-navy">Email Address <span class="text-emergency">*</span></label>
        <input type="email" id="email" name="email" required class="w-full px-4 py-2.5 rounded-lg bg-light border border-border focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent transition-shadow text-sm text-text" placeholder="john@example.com" />
        <span class="error-msg text-xs text-emergency hidden" data-for="email"></span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
      <div class="flex flex-col gap-2">
        <label for="phone" class="text-sm font-semibold text-navy">UK Phone Number</label>
        <input type="tel" id="phone" name="phone" class="w-full px-4 py-2.5 rounded-lg bg-light border border-border focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent transition-shadow text-sm text-text" placeholder="07123 456789" />
        <span class="error-msg text-xs text-emergency hidden" data-for="phone"></span>
      </div>
      
      <div class="flex flex-col gap-2">
        <label for="service" class="text-sm font-semibold text-navy">Service of Interest</label>
        <select id="service" name="service" class="w-full px-4 py-2.5 rounded-lg bg-light border border-border focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent transition-shadow text-sm text-text appearance-none">
          <option value="">Please select...</option>
          {serviceTitles.map((title) => (
            <option value={title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>{title}</option>
          ))}
        </select>
        <span class="error-msg text-xs text-emergency hidden" data-for="service"></span>
      </div>
    </div>

    <div class="flex flex-col gap-2">
      <label for="message" class="text-sm font-semibold text-navy">How can we help? <span class="text-emergency">*</span></label>
      <textarea id="message" name="message" required rows="5" class="w-full px-4 py-2.5 rounded-lg bg-light border border-border focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent transition-shadow text-sm text-text resize-y" placeholder="Please provide details about your security requirements..."></textarea>
      <span class="error-msg text-xs text-emergency hidden" data-for="message"></span>
    </div>

    <div class="mt-4">
      <button type="submit" id="submit-btn" class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-bold tracking-wide uppercase transition-all duration-200 rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 w-full sm:w-auto bg-navy text-white hover:bg-navy-light focus:ring-navy cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
        <span id="btn-text">Send Enquiry</span>
        <svg id="btn-spinner" class="w-5 h-5 animate-spin hidden" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </button>
      <p class="text-[10px] text-steel-light mt-3">This site is protected by our strict privacy policy. Your data will not be shared with third parties.</p>
    </div>
  </form>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLSpanElement;
  const btnSpinner = document.getElementById('btn-spinner') as HTMLElement;
  const alertsContainer = document.getElementById('form-alerts') as HTMLDivElement;
  const alertSuccess = document.getElementById('alert-success') as HTMLDivElement;
  const alertError = document.getElementById('alert-error') as HTMLDivElement;
  const errorMessageEl = document.getElementById('error-message') as HTMLSpanElement;

  function clearErrors() {
    document.querySelectorAll('.error-msg').forEach(el => {
      el.textContent = '';
      el.classList.add('hidden');
    });
    document.querySelectorAll('input, textarea, select').forEach(el => {
      el.classList.remove('border-emergency', 'ring-emergency');
    });
    alertsContainer.classList.add('hidden');
    alertSuccess.classList.add('hidden');
    alertError.classList.add('hidden');
    alertError.classList.remove('flex');
    alertSuccess.classList.remove('flex');
  }

  function setSubmitting(isSubmitting: boolean) {
    submitBtn.disabled = isSubmitting;
    if (isSubmitting) {
      btnText.textContent = 'Sending...';
      btnSpinner.classList.remove('hidden');
    } else {
      btnText.textContent = 'Send Enquiry';
      btnSpinner.classList.add('hidden');
    }
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearErrors();
      setSubmitting(true);

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      
        let sent = false;

        // 1. Try sending via Astro SSR Resend API route
        try {
          const resendResp = await fetch('/api/send-email', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: data.name,
              email: data.email,
              phone: data.phone,
              service: data.service,
              message: data.message
            }),
          });
          const resendResult = await resendResp.json().catch(() => null);
          if (resendResp.ok && resendResult && resendResult.success) {
            sent = true;
          }
        } catch (err) {
          // Fail silently to try fallback
        }

        // 2. Fallback to Web3Forms if Resend is not configured or failed
        if (!sent) {
          data.access_key = (import.meta.env.PUBLIC_WEB3FORMS_KEY || "YOUR_WEB3FORMS_ACCESS_KEY_HERE").trim();
          data.subject = "New Form Submission from SQS Security";
          data.from_name = "SQS Website";

          try {
            const response = await fetch('https://api.web3forms.com/submit', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
              },
              body: JSON.stringify(data),
            });
            if (response.status === 200) {
              sent = true;
            }
          } catch (err) {
            // Network error
          }
        }

        if (sent) {
          // Success
          form.reset();
          alertsContainer.classList.remove('hidden');
          alertsContainer.classList.add('flex');
          alertSuccess.classList.remove('hidden');
          alertSuccess.classList.add('flex');
        } else {
          // Error
          alertsContainer.classList.remove('hidden');
          alertsContainer.classList.add('flex');
          alertError.classList.remove('hidden');
          alertError.classList.add('flex');
          errorMessageEl.textContent = 'An error occurred while submitting your enquiry. Please try again.';
        }

        setSubmitting(false);
    });
  }
</script>
