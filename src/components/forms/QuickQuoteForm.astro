---
import { sanityClient } from '@lib/sanity';

const fetchedServices = await sanityClient.fetch(`*[_type == "service"] | order(order asc)[0...8] {
  title
}`).catch(() => []);

const serviceTitles = [...fetchedServices.map((s: any) => s.title), 'Other'];

interface Props {
  class?: string;
}

const { class: className = "relative overflow-hidden min-h-[600px] sm:min-h-[520px]" } = Astro.props;
---

<form class={`quick-quote-form ${className}`} action="/contact" method="GET">
  <!-- Step 1: Select Service Grid -->
  <div class="step-1 absolute w-full h-full transition-transform duration-500 transform translate-x-0 bg-[#f8f9fa] z-10">
    <label class="block text-slate-800 font-medium text-sm md:text-base mb-4">Your Property Type? <span class="text-red-500">*</span></label>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 md:gap-4 mb-8 px-2 -mx-2 py-2 -my-2">
      {[
        { name: 'Corporate / Commercial', icon: '<svg class="w-8 h-8 mb-2 text-slate-600 peer-checked:text-gold-dark transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"></path><path d="M4 21V8l8-5 8 5v13"></path><path d="M7 21v-9a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v9"></path><path d="M7 14h10"></path><path d="M7 17h10"></path></svg>' },
        { name: 'Construction Security', icon: '<svg class="w-8 h-8 mb-2 text-slate-600 peer-checked:text-gold-dark transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M16 10h-8a4 4 0 0 1 8 0z"></path><path d="M7 10h10"></path><path d="M18 21v-2a4 4 0 0 0-4-4H10a4 4 0 0 0-4 4v2"></path><path d="M9 10v1a3 3 0 0 0 6 0v-1"></path></svg>' },
        { name: 'Property Management / Residential', icon: '<svg class="w-8 h-8 mb-2 text-slate-600 peer-checked:text-gold-dark transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M11 11V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v16h2"></path><path d="M15 7h2"></path><path d="M15 11h2"></path><path d="M15 15h2"></path><path d="M3 21h8"></path><path d="M3 21v-8l4-4 4 4v8"></path><path d="M7 15v6"></path></svg>' },
        { name: 'Healthcare / Education', icon: '<svg class="w-8 h-8 mb-2 text-slate-600 peer-checked:text-gold-dark transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><path d="M9 14h6"></path><path d="M12 11v6"></path></svg>' },
        { name: 'Local Authority', icon: '<svg class="w-8 h-8 mb-2 text-slate-600 peer-checked:text-gold-dark transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M13 21V7a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v14"></path><path d="M16 9h.01"></path><path d="M16 13h.01"></path><path d="M16 17h.01"></path><path d="M19 9h.01"></path><path d="M19 13h.01"></path><path d="M19 17h.01"></path><path d="M8 12a4 4 0 0 1 0-8 4 4 0 0 1 0 8z"></path><path d="M8 12v9"></path><path d="M3 21h18"></path></svg>' },
        { name: 'Student Accommodation', icon: '<svg class="w-8 h-8 mb-2 text-slate-600 peer-checked:text-gold-dark transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21h16"></path><path d="M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16"></path><path d="M10 21v-4h4v4"></path><path d="M9 7h2"></path><path d="M13 7h2"></path><path d="M9 11h2"></path><path d="M13 11h2"></path><path d="M9 15h2"></path><path d="M13 15h2"></path></svg>' },
        { name: 'Maritime', icon: '<svg class="w-8 h-8 mb-2 text-slate-600 peer-checked:text-gold-dark transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M22 18H2a4 4 0 0 0 4 4h12a4 4 0 0 0 4-4Z"></path><path d="M21 14 10 2 3 14h18Z"></path><path d="M10 2v16"></path></svg>' },
        { name: 'Other', icon: '<svg class="w-8 h-8 mb-2 text-slate-600 peer-checked:text-gold-dark transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><circle cx="12" cy="17" r="1" fill="currentColor" stroke="none"></circle></svg>' },
      ].map((item) => (
        <label class="cursor-pointer group relative">
          <input type="radio" name="property_type" value={item.name} class="peer sr-only" required />
          <div class="bg-[#f8f9fa] border border-slate-300 rounded-xl shadow-md hover:shadow-xl hover:shadow-slate-300/50 hover:-translate-y-1 p-3 md:p-4 text-center transition-all duration-300 peer-checked:border-gold-dark peer-checked:ring-2 peer-checked:ring-gold/30 peer-checked:bg-white peer-checked:shadow-xl peer-checked:shadow-gold/20 peer-checked:-translate-y-1 h-[100px] md:h-[115px] flex flex-col items-center justify-center">
            <Fragment set:html={item.icon} />
            <span class="text-[10px] md:text-xs font-normal text-slate-600 leading-tight group-hover:text-slate-900 transition-colors" set:html={item.name.replace(' / ', ' / <br/>')}></span>
          </div>
        </label>
      ))}
    </div>
    <div class="flex items-start mt-2 md:mt-4">
      <button type="button" class="btn-next-1 inline-flex bg-gold hover:bg-gold-dark text-white font-bold text-base px-8 py-2.5 rounded shadow-md hover:shadow-lg transition-all duration-300 items-center justify-center gap-2 cursor-pointer">
        Next Step
        <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"/></svg>
      </button>
    </div>
  </div>

  <!-- Step 2: Select Services -->
  <div class="step-2 absolute w-full h-full transition-transform duration-500 transform translate-x-full invisible bg-[#f8f9fa] z-0 flex flex-col">
    <label class="block text-slate-800 font-medium text-sm md:text-base mb-6">Select your Services <span class="text-red-500">*</span></label>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-y-0.5 gap-x-6 mb-8 flex-grow">
      {serviceTitles.map((srv) => (
        <label class="flex items-center gap-3 cursor-pointer group">
          <div class="relative flex items-center justify-center">
            <input type="checkbox" name="services" value={srv} class="peer appearance-none w-5 h-5 border border-slate-300 rounded-[4px] bg-white checked:bg-gold-dark checked:border-gold-dark transition-all cursor-pointer shadow-sm" />
            <svg class="absolute w-3.5 h-3.5 text-white opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span class="text-[14px] md:text-[15px] font-normal text-slate-600 group-hover:text-slate-900 transition-colors leading-tight">{srv}</span>
        </label>
      ))}
    </div>
    <div class="flex items-center justify-between mt-auto">
      <button type="button" class="btn-prev-2 inline-flex bg-gold hover:bg-gold-dark text-white font-bold text-base px-6 py-2.5 rounded shadow-md hover:shadow-lg transition-all duration-300 items-center justify-center gap-2 cursor-pointer">
        <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"/></svg>
        Prev Step
      </button>
      <button type="button" class="btn-next-2 inline-flex bg-gold hover:bg-gold-dark text-white font-bold text-base px-6 py-2.5 rounded shadow-md hover:shadow-lg transition-all duration-300 items-center justify-center gap-2 cursor-pointer">
        Next Step
        <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"/></svg>
      </button>
    </div>
  </div>

  <!-- Step 3: Contact Details -->
  <div class="step-3 absolute w-full h-full transition-transform duration-500 transform translate-x-full invisible bg-[#f8f9fa] z-0 flex flex-col">
    <label class="block text-slate-800 font-medium text-sm md:text-base mb-4">Your Details <span class="text-red-500">*</span></label>
    <div class="flex flex-col gap-4 mb-6 flex-grow">
      <div>
        <input type="text" name="name" class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-navy font-medium placeholder-slate-400 focus:outline-none focus:border-gold-dark focus:ring-2 focus:ring-gold/20 transition-all shadow-sm" placeholder="Full Name *" required />
      </div>
      <div>
        <input type="email" name="email" class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-navy font-medium placeholder-slate-400 focus:outline-none focus:border-gold-dark focus:ring-2 focus:ring-gold/20 transition-all shadow-sm" placeholder="Email Address *" required />
      </div>
      <div>
        <input type="tel" name="phone" class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-navy font-medium placeholder-slate-400 focus:outline-none focus:border-gold-dark focus:ring-2 focus:ring-gold/20 transition-all shadow-sm" placeholder="Phone Number *" required />
      </div>
      <div>
        <textarea name="notes" rows="3" class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-navy font-medium placeholder-slate-400 focus:outline-none focus:border-gold-dark focus:ring-2 focus:ring-gold/20 transition-all shadow-sm resize-none" placeholder="Note / Requirements"></textarea>
      </div>
    </div>
    <div class="flex items-center justify-between mt-auto">
      <button type="button" class="btn-prev-3 inline-flex bg-gold hover:bg-gold-dark text-white font-bold text-base px-6 py-2.5 rounded shadow-md hover:shadow-lg transition-all duration-300 items-center justify-center gap-2 cursor-pointer">
        <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"/></svg>
        Prev Step
      </button>
      <button type="submit" class="btn-submit inline-flex bg-gold hover:bg-gold-dark text-white font-bold text-base px-6 py-2.5 rounded shadow-md hover:shadow-lg transition-all duration-300 items-center justify-center gap-2 cursor-pointer">
        Submit Quote
        <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
      </button>
    </div>
  </div>
</form>

<script>
  function setupQuickQuoteForms() {
    document.querySelectorAll('.quick-quote-form').forEach((form) => {
      // Prevent multiple initializations if script runs more than once
      if (form.classList.contains('js-initialized')) return;
      form.classList.add('js-initialized');

      const btnNext1 = form.querySelector('.btn-next-1') as HTMLButtonElement;
      const btnPrev2 = form.querySelector('.btn-prev-2') as HTMLButtonElement;
      const btnNext2 = form.querySelector('.btn-next-2') as HTMLButtonElement;
      const btnPrev3 = form.querySelector('.btn-prev-3') as HTMLButtonElement;
      
      const step1 = form.querySelector('.step-1') as HTMLDivElement;
      const step2 = form.querySelector('.step-2') as HTMLDivElement;
      const step3 = form.querySelector('.step-3') as HTMLDivElement;

      if (btnNext1 && step1 && step2) {
        btnNext1.addEventListener('click', () => {
          const checkedProp = form.querySelector('input[name="property_type"]:checked');
          if (!checkedProp) {
            alert('Please select a property type to continue.');
            return;
          }
          step1.classList.add('-translate-x-full', 'invisible');
          step1.classList.remove('translate-x-0', 'z-10');
          
          step2.classList.remove('translate-x-full', 'invisible');
          step2.classList.add('translate-x-0', 'z-10');
        });
      }

      if (btnPrev2 && step1 && step2) {
        btnPrev2.addEventListener('click', () => {
          step2.classList.add('translate-x-full', 'invisible');
          step2.classList.remove('translate-x-0', 'z-10');
          
          step1.classList.remove('-translate-x-full', 'invisible');
          step1.classList.add('translate-x-0', 'z-10');
        });
      }

      if (btnNext2 && step2 && step3) {
        btnNext2.addEventListener('click', () => {
          const selectedServices = form.querySelectorAll('input[name="services"]:checked');
          if (selectedServices.length === 0) {
            alert('Please select at least one service.');
            return;
          }
          step2.classList.add('-translate-x-full', 'invisible');
          step2.classList.remove('translate-x-0', 'z-10');
          
          step3.classList.remove('translate-x-full', 'invisible');
          step3.classList.add('translate-x-0', 'z-10');
        });
      }

      if (btnPrev3 && step2 && step3) {
        btnPrev3.addEventListener('click', () => {
          step3.classList.add('translate-x-full', 'invisible');
          step3.classList.remove('translate-x-0', 'z-10');
          
          step2.classList.remove('-translate-x-full', 'invisible');
          step2.classList.add('translate-x-0', 'z-10');
        });
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = 'Sending...';
        submitBtn.disabled = true;

        const formData = new FormData(form as HTMLFormElement);
        const data = Object.fromEntries(formData.entries()) as any;
        
        // Handle multiple checkboxes manually
        const selectedServices = Array.from(form.querySelectorAll('input[name="services"]:checked')).map((cb: any) => cb.value);
        data.services = selectedServices.join(', ');

        data.access_key = "YOUR_WEB3FORMS_ACCESS_KEY_HERE";
        data.subject = "New Quick Quote Request from SQS Website";
        data.from_name = "SQS Website";

        try {
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify(data),
          });

          if (response.status === 200) {
            alert('Quote request sent successfully! We will contact you soon.');
            (form as HTMLFormElement).reset();
            
            // Reset view to Step 1
            if (step1 && step3) {
              step3.classList.add('translate-x-full', 'invisible');
              step3.classList.remove('translate-x-0', 'z-10');
              
              step1.classList.remove('-translate-x-full', 'invisible');
              step1.classList.add('translate-x-0', 'z-10');
            }

            // Custom event to notify modal parent to close if necessary
            form.dispatchEvent(new CustomEvent('quote-submitted'));
          } else {
            alert('An error occurred while sending your request. Please try again.');
          }
        } catch (err) {
          alert('A network error occurred. Please check your connection and try again.');
        } finally {
          submitBtn.innerHTML = originalText;
          submitBtn.disabled = false;
        }
      });
    });
  }

  // Initialize on page load
  setupQuickQuoteForms();
  // Support Astro view transitions / client-side routing
  document.addEventListener('astro:page-load', setupQuickQuoteForms);
</script>
