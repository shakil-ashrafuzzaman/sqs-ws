---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

// Get segments from current pathname
const { pathname } = Astro.url;
const segments = pathname.split('/').filter(Boolean);

// Create breadcrumbs data array
const breadcrumbs = [
  { name: 'Home', href: '/', isLast: segments.length === 0 },
  ...segments.map((segment, index) => {
    const href = '/' + segments.slice(0, index + 1).join('/');
    // Convert e.g. "manned-guarding" to "Manned Guarding"
    const name = segment
      .split('-')
      .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
      .join(' ');
    const isLast = index === segments.length - 1;
    return { name, href, isLast };
  }),
];
---

{
  segments.length > 0 && (
    <nav aria-label="Breadcrumb" class={`bg-light py-3 px-4 rounded-md border border-border text-sm mb-6 ${className}`}>
      <ol class="flex flex-wrap items-center gap-2 list-none m-0 p-0">
        {breadcrumbs.map((crumb, idx) => (
          <li class="flex items-center gap-2 text-steel-dark">
            {idx > 0 && (
              <svg class="w-3 h-3 text-steel-light shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            )}
            {crumb.isLast ? (
              <span class="font-semibold text-navy" aria-current="page">
                {crumb.name}
              </span>
            ) : (
              <a href={crumb.href} class="hover:text-gold transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-gold py-0.5 px-1 rounded">
                {crumb.name}
              </a>
            )}
          </li>
        ))}
      </ol>
    </nav>
  )
}
