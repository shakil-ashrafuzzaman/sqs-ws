---
import Button from '@components/common/Button.astro';
import { sanityClient, urlFor } from '@lib/sanity';

// Fetch Site Settings & Contact Info from Sanity
const siteQuery = `*[_type == "siteSettings"][0]{
  siteName,
  logoMain
}`;
const contactQuery = `*[_type == "contactInfo"][0]{
  phone,
  emergencyPhone,
  email
}`;

const [siteSettings, contactInfo] = await Promise.all([
  sanityClient.fetch(siteQuery).catch(() => null),
  sanityClient.fetch(contactQuery).catch(() => null)
]);

const phoneMain = contactInfo?.phone || '023 8012 3456';
const phoneEmergency = contactInfo?.emergencyPhone || '0800 999 1234';
const emailMain = contactInfo?.email || 'info@sqssecurity.co.uk';

const navLinks = [
  { name: 'Home', href: '/' },
  { 
    name: 'Services', 
    href: '/services',
    dropdown: [
      { name: 'Security Guarding', href: '/services/security-guarding' },
      { name: 'Waking Watch', href: '/services/waking-watch' },
      { name: 'Construction Security', href: '/services/construction-security' },
      { name: 'Dog Handler / K9', href: '/services/dog-handler-k9' },
      { name: 'Warehouse Security', href: '/services/warehouse-security' },
      { name: 'Office Security', href: '/services/office-security' },
      { name: 'Void Property', href: '/services/void-property' },
      { name: 'Emergency Cover', href: '/services/emergency-cover' },
    ]
  },
  {
    name: 'Areas',
    href: '#',
    dropdown: [
      { name: 'Southampton', href: '/security-company-southampton' },
      { name: 'London', href: '/security-company-london' },
      { name: 'Manchester', href: '/security-company-manchester' },
      { name: 'Brighton', href: '/security-company-brighton' },
      { name: 'Portsmouth', href: '/security-company-portsmouth' },
      { name: 'Birmingham', href: '/security-company-birmingham' },
      { name: 'Leeds', href: '/security-company-leeds' },
      { name: 'Bristol', href: '/security-company-bristol' },
    ]
  },
  { name: 'About', href: '/about' },
  { name: 'Blog', href: '/blog' },
  { name: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;

const isActive = (href) => {
  if (href === '/') return currentPath === '/';
  if (href === '#') return false; 
  return currentPath.startsWith(href);
};
---

<header class="w-full relative z-50">
  <!-- Main Navigation Bar -->
  <nav class="bg-white/95 backdrop-blur-md border-b border-border shadow-sm sticky top-0 z-50 transition-all duration-300">
    <div class="w-full px-6 md:px-16 lg:px-24 py-4 md:py-5 flex justify-between items-center">
      <!-- SQS Logo & 3D Text Wrapper -->
      <div class={`h-12 md:h-16 flex items-center shrink-0 relative z-[60] ${siteSettings?.logoMain?.asset ? '' : 'gap-3 md:gap-5 -ml-8 md:-ml-16 lg:-ml-24'}`}>
        
        {siteSettings?.logoMain?.asset ? (
          <!-- Sanity Uploaded Logo Only -->
          <a href="/" class="flex items-center focus-visible:outline focus-visible:outline-gold z-10" aria-label={`${siteSettings?.siteName || 'SQS Security'} Homepage`}>
            <img 
              src={urlFor(siteSettings.logoMain).width(800).url()} 
              alt={siteSettings.logoMain?.alt || "SQS Security Logo"} 
              class="h-10 md:h-12 lg:h-14 w-auto object-contain transition-transform duration-300 hover:scale-105"
            />
          </a>
        ) : (
          <!-- Current Fallback Design (Shield + Security Service Text) -->
          <>
            <!-- Absolute Overhanging Logo -->
            <a href="/" class="absolute top-1/2 -translate-y-1/2 left-4 md:left-6 lg:left-8 flex items-center focus-visible:outline focus-visible:outline-gold z-10" aria-label={`${siteSettings?.siteName || 'SQS Security'} Homepage`}>
              <img 
                src="/sqs-logo.png" 
                alt="SQS Security Logo" 
                class="h-28 md:h-32 w-auto object-contain transition-transform duration-300 hover:scale-105 drop-shadow-[0_8px_16px_rgba(0,0,0,0.25)]"
                width="500"
                height="140"
              />
            </a>
            
            <!-- Spacer for the absolute logo to prevent line collision -->
            <div class="w-28 md:w-40 shrink-0"></div>
            
            <!-- Load Athletic Block Font to match SQS Logo -->
            <link href="https://fonts.googleapis.com/css2?family=Squada+One&display=swap" rel="stylesheet" />
            <!-- Text inside the white header -->
            <div class="flex flex-col justify-center font-black uppercase tracking-wider text-navy antialiased relative pt-1" style="font-family: 'Squada One', Impact, sans-serif; letter-spacing: 0.05em; font-weight: 400;">
              <!-- SQS (Top Line) -->
              <div class="text-center text-lg sm:text-2xl text-gold leading-none mb-0.5 sm:mb-1 tracking-widest">
                SQS
              </div>
              
              <!-- Security Service (Bottom Line) -->
              <div class="flex items-center gap-1.5 sm:gap-3 text-[1.2rem] min-[400px]:text-xl sm:text-3xl md:text-[2.25rem] leading-none">
                <span class="text-gold text-[0.65em] -translate-y-[2px]">★</span>
                <span>Security Service</span>
                <span class="text-gold text-[0.65em] -translate-y-[2px]">★</span>
              </div>
              <!-- Extended Navy Underline -->
              <div class="absolute -bottom-1 -left-2 sm:-left-4 -right-2 sm:-right-4 h-[3px] sm:h-[4px] bg-navy"></div>
            </div>
          </>
        )}
      </div>

      <!-- Desktop Navigation Menu -->
      <div class="hidden lg:flex items-center gap-8">
        <div class="flex items-center gap-6 font-display font-bold text-navy text-lg lg:text-xl">
          {navLinks.map((link) => {
            const active = isActive(link.href);
            return link.dropdown ? (
              <div class="relative group py-6">
                <a 
                  href={link.href} 
                  class={`flex items-center gap-1.5 transition-colors relative focus-visible:outline-none focus-visible:text-gold ${active ? 'text-gold' : 'hover:text-gold'}`}
                >
                  {link.name}
                  <svg class={`w-4 h-4 transition-transform duration-300 group-hover:rotate-180 ${active ? 'text-gold' : 'text-steel group-hover:text-gold'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </a>
                
                <!-- Dropdown Menu -->
                <div class="absolute top-full left-1/2 -translate-x-1/2 mt-0 w-64 bg-white/95 backdrop-blur-xl shadow-[0_10px_40px_rgba(0,0,0,0.08)] border border-border/60 rounded-xl opacity-0 invisible translate-y-3 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-300 z-50 overflow-hidden">
                  <div class="flex flex-col py-2">
                    {link.dropdown.map(subItem => {
                      const subActive = currentPath === subItem.href;
                      return (
                        <a href={subItem.href} class={`px-6 py-2.5 text-[15px] font-semibold transition-colors border-b border-light last:border-0 flex items-center justify-between group/item ${subActive ? 'text-[#20B2AA] bg-light/50' : 'text-steel-dark hover:text-[#20B2AA] hover:bg-light'}`}>
                          {subItem.name}
                          <svg class={`w-4 h-4 transition-all duration-300 ${subActive ? 'opacity-100 translate-x-0 text-[#20B2AA]' : 'opacity-0 -translate-x-2 group-hover/item:opacity-100 group-hover/item:translate-x-0'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                          </svg>
                        </a>
                      );
                    })}
                  </div>
                </div>
              </div>
            ) : (
              <div class="py-6">
                <a 
                  href={link.href} 
                  class={`transition-colors relative py-1 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:bg-gold after:transition-all after:duration-300 focus-visible:outline-none focus-visible:text-gold ${active ? 'text-gold after:w-full' : 'hover:text-gold after:w-0 hover:after:w-full'}`}
                >
                  {link.name}
                </a>
              </div>
            )
          })}
        </div>

        <Button href="/contact" variant="primary" size="sm" class="shadow-md">
          Request a Quote
        </Button>
      </div>

      <!-- Mobile navigation elements -->
      <div class="flex items-center gap-3 lg:hidden">

        <!-- Hamburger Icon -->
        <button 
          id="mobile-menu-toggle" 
          class="text-navy p-1.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-gold rounded" 
          aria-expanded="false" 
          aria-controls="mobile-menu"
          aria-label="Toggle Navigation Menu"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7" />
            <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Emergency banner below header -->
  <div class="bg-ice-blue text-navy text-xs md:text-sm font-semibold py-2.5 shadow-sm relative z-40 overflow-hidden">
    <div class="container flex flex-col md:flex-row justify-between items-center gap-4">

      <!-- Left: Continuous Marquee (Left to Right) -->
      <div class="flex-1 overflow-hidden relative flex items-center max-w-full md:max-w-[65%] w-full -ml-4 md:-ml-8 lg:-ml-12">
        <!-- Mask gradient to fade the edges of the marquee smoothly into the ice-blue background -->
        <div class="absolute inset-0 z-10 pointer-events-none" style="background: linear-gradient(to right, var(--color-ice-blue) 0%, transparent 5%, transparent 90%, var(--color-ice-blue) 100%);"></div>
        
        <div class="flex whitespace-nowrap animate-marquee-ltr w-max">
          <!-- Set 1 -->
          <div class="flex items-center w-max shrink-0 px-2">
            <span class="inline-flex items-center gap-1.5 mx-4 md:mx-6">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path d="M2 10.5a1.5 1.5 0 113 0v6a1.5 1.5 0 01-3 0v-6zM6 10.333v5.43a2 2 0 001.106 1.79l.05.025A4 4 0 008.943 18h5.416a2 2 0 001.962-1.608l1.2-6A2 2 0 0015.56 8H12V4a2 2 0 00-2-2 1 1 0 00-1 1v.667a4 4 0 01-.8 2.4L6.8 7.933a4 4 0 00-.8 2.4z" /></svg>
              99% Retention Rate
            </span>
            <span class="inline-flex items-center gap-1.5 mx-4 md:mx-6">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" /></svg>
              Available 24/7
            </span>
            <span class="inline-flex items-center gap-1.5 mx-4 md:mx-6">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
              Coverage Over UK
            </span>
          </div>
          <!-- Set 2 -->
          <div class="flex items-center w-max shrink-0 px-2">
            <span class="inline-flex items-center gap-1.5 mx-4 md:mx-6">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path d="M2 10.5a1.5 1.5 0 113 0v6a1.5 1.5 0 01-3 0v-6zM6 10.333v5.43a2 2 0 001.106 1.79l.05.025A4 4 0 008.943 18h5.416a2 2 0 001.962-1.608l1.2-6A2 2 0 0015.56 8H12V4a2 2 0 00-2-2 1 1 0 00-1 1v.667a4 4 0 01-.8 2.4L6.8 7.933a4 4 0 00-.8 2.4z" /></svg>
              99% Retention Rate
            </span>
            <span class="inline-flex items-center gap-1.5 mx-4 md:mx-6">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" /></svg>
              Available 24/7
            </span>
            <span class="inline-flex items-center gap-1.5 mx-4 md:mx-6">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
              Coverage Over UK
            </span>
          </div>
        </div>
      </div>

      <!-- Right: Main Phone & Email -->
      <div class="flex items-center gap-6 text-sm md:text-base">
        <a href={`tel:${phoneMain.replace(/\s+/g, '')}`} class="hidden md:flex items-center gap-1.5 hover:text-gold-dark transition-colors whitespace-nowrap text-navy">
          <svg class="w-4.5 h-4.5 text-gold-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span class="font-bold">{phoneMain}</span>
        </a>
        <span class="hidden md:inline text-steel/40">|</span>
        <a href={`mailto:${emailMain}`} class="flex items-center gap-1.5 hover:text-gold-dark transition-colors whitespace-nowrap text-navy">
          <svg class="w-4.5 h-4.5 text-gold-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 00-2 2z" />
          </svg>
          <span>{emailMain}</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div 
    id="mobile-menu" 
    class="hidden absolute top-full left-0 w-full bg-white border-b border-border shadow-lg lg:hidden max-h-[80vh] overflow-y-auto"
    role="region"
    aria-label="Mobile Navigation"
  >
    <div class="px-6 py-6 flex flex-col gap-4 font-display font-medium text-navy text-lg">
      {navLinks.map((link) => {
        const active = isActive(link.href);
        return (
        <div class="flex flex-col border-b border-light last:border-0 pb-2">
          {link.dropdown ? (
            <details class="group/accordion">
              <summary class="flex justify-between items-center py-2 font-bold cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                <span class={`transition-colors ${active ? 'text-gold' : 'hover:text-[#20B2AA]'}`}>{link.name}</span>
                <svg class="w-5 h-5 text-steel transition-transform duration-300 group-open/accordion:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="pl-4 flex flex-col gap-2 pt-2 pb-2">
                {link.dropdown.map(subItem => {
                  const subActive = currentPath === subItem.href;
                  return (
                  <a href={subItem.href} class={`text-[15px] transition-colors flex items-center gap-2 group/sub ${subActive ? 'text-[#20B2AA] font-semibold' : 'text-steel-dark hover:text-[#20B2AA]'}`}>
                    <span class={`w-1.5 h-1.5 rounded-full transition-colors ${subActive ? 'bg-[#20B2AA]' : 'bg-gold group-hover/sub:bg-[#20B2AA]'}`}></span>
                    {subItem.name}
                  </a>
                )})}
              </div>
            </details>
          ) : (
            <a href={link.href} class={`py-2 transition-colors font-bold ${active ? 'text-gold' : 'hover:text-[#20B2AA]'}`}>
              {link.name}
            </a>
          )}
        </div>
      )})}
      <div class="pt-4 flex flex-col gap-3">
        <div class="text-xs text-steel-dark text-center flex flex-col gap-1.5 py-2">
          <span>📞 Main Office: {phoneMain}</span>
          <span>✉️ Email: {emailMain}</span>
        </div>
        <Button href="/contact" variant="primary" class="w-full text-center">
          Request a Quote
        </Button>
      </div>
    </div>
  </div>
</header>

<script>
  // Setup mobile navigation toggle behavior
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', () => {
      const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
      
      menuToggle.setAttribute('aria-expanded', String(!isExpanded));
      mobileMenu.classList.toggle('hidden');
      
      if (hamburgerIcon && closeIcon) {
        hamburgerIcon.classList.toggle('hidden');
        closeIcon.classList.toggle('hidden');
      }
    });
  }
</script>
