---
import PageLayout from '@layouts/PageLayout.astro';
import Badge from '@components/common/Badge.astro';
import Button from '@components/common/Button.astro';
import Card from '@components/common/Card.astro';
import { sanityClient } from '@lib/sanity';

export async function getStaticPaths() {
  const areas = [
    {
      localArea: 'southampton',
      name: 'Southampton',
      isHQ: true,
      description: 'As our head office location, SQS Security provides unmatched rapid response and comprehensive security services across Southampton and surrounding Hampshire areas.',
      concerns: 'With a bustling port and large commercial districts, Southampton requires robust maritime security, retail loss prevention, and rapid alarm response for industrial estates.',
      responseTime: 'Under 15 minutes',
      coordinates: { lat: '50.9097', lon: '-1.4044' },
      testimonial: {
        quote: 'SQS Security has secured our Southampton logistics hub for 3 years. Their local presence means they respond to alarms incredibly fast.',
        author: 'Mark T.',
        company: 'Southampton Freight Co.'
      }
    },
    {
      localArea: 'london',
      name: 'London',
      isHQ: false,
      description: 'Providing elite corporate, retail, and event security solutions across Greater London, protecting some of the capital\'s most prestigious addresses.',
      concerns: 'London\'s dense corporate and retail environments demand high-end concierge security, advanced loss prevention, and strict access control to mitigate corporate espionage and theft.',
      responseTime: '30-45 minutes (depending on borough)',
      coordinates: { lat: '51.5074', lon: '-0.1278' },
      testimonial: {
        quote: 'The corporate security team provided by SQS for our London HQ is exceptional. They balance 5-star customer service with absolute vigilance.',
        author: 'Sarah J.',
        company: 'City Financial Corp'
      }
    },
    {
      localArea: 'manchester',
      name: 'Manchester',
      isHQ: false,
      description: 'Delivering robust construction, corporate, and event security services across Manchester and the wider North West region.',
      concerns: 'Rapid urban development and busy nightlife require specialized construction site protection and SIA door supervision to maintain public safety.',
      responseTime: 'Under 30 minutes',
      coordinates: { lat: '53.4808', lon: '-2.2426' },
      testimonial: {
        quote: 'Excellent construction site security. We haven\'t lost a single piece of machinery since SQS took over our Manchester development.',
        author: 'David R.',
        company: 'Northern Build Ltd'
      }
    },
    {
      localArea: 'birmingham',
      name: 'Birmingham',
      isHQ: false,
      description: 'Comprehensive security guarding and mobile patrol services securing commercial and industrial properties across Birmingham and the Midlands.',
      concerns: 'Vast industrial parks and logistical hubs in the Midlands face high risks of cargo theft and unauthorized access, demanding strong perimeter defense.',
      responseTime: 'Under 30 minutes',
      coordinates: { lat: '52.4862', lon: '-1.8904' },
      testimonial: {
        quote: 'Their mobile patrols have been a fantastic deterrent for our Birmingham warehouse. Highly professional officers.',
        author: 'James W.',
        company: 'Midland Distribution'
      }
    },
    {
      localArea: 'leeds',
      name: 'Leeds',
      isHQ: false,
      description: 'Tailored retail, corporate, and mobile security patrols protecting businesses in Leeds and the Yorkshire region.',
      concerns: 'A booming retail sector and expanding corporate offices require sophisticated loss prevention and concierge-level access control.',
      responseTime: 'Under 35 minutes',
      coordinates: { lat: '53.8008', lon: '-1.5491' },
      testimonial: {
        quote: 'SQS transformed the security at our Leeds shopping center. Shoplifting is down and our customers feel much safer.',
        author: 'Emma P.',
        company: 'Retail Parks Group'
      }
    },
    {
      localArea: 'liverpool',
      name: 'Liverpool',
      isHQ: false,
      description: 'Specialist maritime, event, and commercial security services for Liverpool and the Merseyside area.',
      concerns: 'Active maritime ports and a vibrant event scene require ISPS compliant port security and expert crowd management teams.',
      responseTime: 'Under 30 minutes',
      coordinates: { lat: '53.4084', lon: '-2.9916' },
      testimonial: {
        quote: 'Flawless crowd management for our Liverpool music festival. The team handled everything professionally and safely.',
        author: 'Chris B.',
        company: 'Mersey Events'
      }
    },
    {
      localArea: 'portsmouth',
      name: 'Portsmouth',
      isHQ: false,
      description: 'Providing elite maritime, defense contractor, and commercial security solutions across Portsmouth.',
      concerns: 'Naval history and active defense contractors necessitate high-clearance guarding, strict access control, and maritime-specific knowledge.',
      responseTime: 'Under 20 minutes',
      coordinates: { lat: '50.8198', lon: '-1.0880' },
      testimonial: {
        quote: 'Given the sensitive nature of our Portsmouth facility, SQS provides exactly the strict, no-nonsense access control we require.',
        author: 'Richard L.',
        company: 'Marine Tech Defense'
      }
    },
    {
      localArea: 'winchester',
      name: 'Winchester',
      isHQ: false,
      description: 'Discreet, highly professional corporate, educational, and residential security patrols for Winchester.',
      concerns: 'Historic university buildings and high-net-worth residential areas require subtle, highly professional guarding and rapid keyholding responses.',
      responseTime: 'Under 25 minutes',
      coordinates: { lat: '51.0632', lon: '-1.3080' },
      testimonial: {
        quote: 'Our Winchester campus has never felt safer. The officers are polite, visible, and engage wonderfully with our students.',
        author: 'Prof. Helen G.',
        company: 'Winchester Education Trust'
      }
    }
  ];

  const contactInfo = await sanityClient.fetch(`*[_type == "contactInfo"][0]{
    phone,
    emergencyPhone,
    addressLine1,
    addressLine2
  }`).catch(() => null);

  return areas.map(area => ({
    params: { localArea: area.localArea },
    props: { area, contactInfo },
  }));
}

const { area, contactInfo } = Astro.props;
const phoneEmergency = contactInfo?.emergencyPhone || '0800 999 1234';

const addressLine1 = contactInfo?.addressLine1 || '86 Brintons Road';
const addressLine2 = contactInfo?.addressLine2 || '';
const hqAddress = addressLine2 ? `${addressLine1}, ${addressLine2}` : addressLine1;

// Local SEO Schema
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "SecurityService",
  "name": `SQS Security ${area.name}`,
  "image": "https://sqssecurity.co.uk/logo.png",
  "@id": `https://sqssecurity.co.uk/security-company-${area.localArea}`,
  "url": `https://sqssecurity.co.uk/security-company-${area.localArea}`,
  "telephone": contactInfo?.emergencyPhone || "08009991234",
  "priceRange": "££",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": area.isHQ ? hqAddress : "Served via SQS Regional Network",
    "addressLocality": area.name,
    "addressCountry": "UK"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": area.coordinates.lat,
    "longitude": area.coordinates.lon
  },
  "areaServed": {
    "@type": "City",
    "name": area.name
  },
  "description": area.description
};

const localServices = [
  { title: `Manned Guarding in ${area.name}`, icon: 'shield', link: '/services/manned-guarding' },
  { title: `Mobile Patrols across ${area.name}`, icon: 'car', link: '/services/mobile-patrols' },
  { title: `Alarm Response in ${area.name}`, icon: 'bell', link: '/services/alarm-response' },
  { title: `CCTV Monitoring for ${area.name}`, icon: 'camera', link: '/services/cctv-monitoring' }
];

const faqs = [
  {
    q: `What is your emergency response time in ${area.name}?`,
    a: `Our target response time for keyholding and emergency alarm activations in ${area.name} is ${area.responseTime}. Our localized dispatch network ensures rapid attendance.`
  },
  {
    q: `Are your security guards in ${area.name} SIA licensed?`,
    a: `Yes. Every security officer deployed by SQS Security in ${area.name} and nationwide holds a valid Security Industry Authority (SIA) licence and is thoroughly vetted to BS7858 standards.`
  },
  {
    q: `Do you provide free security assessments for ${area.name} businesses?`,
    a: `Absolutely. We offer comprehensive, no-obligation site security assessments for commercial properties, retail stores, and construction sites throughout ${area.name}.`
  }
];
---

<PageLayout 
  title={`Security Company ${area.name} | Top Security Services in ${area.name}`}
  description={`Looking for a reliable security company in ${area.name}? SQS Security provides SIA licensed guards, mobile patrols, and rapid alarm response across ${area.name}.`}
>
  <!-- Inject Local SEO Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

  <!-- Hero Section -->
  <section class="bg-navy py-16 md:py-24 text-white relative overflow-hidden">
    <!-- Map background subtle pattern -->
    <div class="absolute inset-0 opacity-5 bg-[linear-gradient(to_right,#64748b_2px,transparent_2px),linear-gradient(to_bottom,#64748b_2px,transparent_2px)] bg-[size:2rem_2rem]"></div>
    
    <div class="container relative z-10 flex flex-col gap-6 max-w-4xl text-center items-center animate-fade-in-up">
      <Badge variant="gold">
        {area.isHQ ? `📍 SQS Security Head Office: ${area.name}` : `📍 Serving ${area.name} & Surrounding Areas`}
      </Badge>
      <h1 class="font-display font-black text-4xl md:text-5xl lg:text-6xl text-white leading-tight">
        Trusted Security Company in <br/>
        <span class="text-gradient-gold">{area.name}</span>
      </h1>
      <p class="text-lg md:text-xl text-steel-light leading-relaxed max-w-2xl">
        {area.description}
      </p>
      <div class="mt-4 flex flex-wrap justify-center gap-4">
        <Button href="/contact" variant="primary" size="lg">Get a Free Quote in {area.name}</Button>
        <Button href={`tel:${phoneEmergency.replace(/\s+/g, '')}`} variant="outline" class="border-white/30 text-white">Call Local Dispatch: {phoneEmergency}</Button>
      </div>
    </div>
  </section>

  <!-- Local Concerns & Intro -->
  <section class="section bg-white border-b border-border">
    <div class="container grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="flex flex-col gap-6">
        <h2 class="font-display font-bold text-3xl text-navy">
          Why Choose SQS Security in {area.name}?
        </h2>
        <p class="text-steel-dark text-lg leading-relaxed">
          {area.concerns}
        </p>
        <p class="text-steel-dark leading-relaxed">
          By utilizing local knowledge and a highly trained regional workforce, SQS Security ensures your property, staff, and assets are protected by officers who understand the specific dynamics and threats of the {area.name} area.
        </p>
        <div class="flex gap-4 mt-2">
          <div class="flex flex-col">
            <span class="font-display font-black text-navy text-3xl">{area.responseTime}</span>
            <span class="text-xs uppercase font-bold text-steel tracking-wider">Average Response Time</span>
          </div>
        </div>
      </div>
      
      <!-- Local Testimonial Highlight -->
      <div class="relative">
        <div class="absolute -inset-4 bg-gold/10 rounded-2xl transform rotate-3"></div>
        <Card class="relative bg-white border-2 border-gold/20 shadow-xl p-8 flex flex-col gap-6 z-10">
          <div class="text-gold">
            <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          </div>
          <p class="text-steel-dark text-lg italic leading-relaxed">"{area.testimonial.quote}"</p>
          <div class="border-t border-border pt-4">
            <h4 class="font-display font-bold text-navy">{area.testimonial.author}</h4>
            <span class="text-sm text-steel">{area.testimonial.company}</span>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Local Services Grid -->
  <section class="section bg-light">
    <div class="container flex flex-col gap-10">
      <div class="text-center max-w-3xl mx-auto">
        <Badge variant="secondary" class="mx-auto mb-4">Core Services</Badge>
        <h2 class="font-display font-bold text-3xl text-navy">Security Services Offered in {area.name}</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {localServices.map(service => (
          <a href={service.link} class="group">
            <Card class="bg-white hover:border-gold/50 transition-colors h-full flex flex-col items-center text-center gap-4 p-6">
              <div class="bg-navy/5 text-navy group-hover:bg-navy group-hover:text-gold w-14 h-14 rounded-full flex items-center justify-center transition-all duration-300">
                {service.icon === 'shield' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>}
                {service.icon === 'car' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>}
                {service.icon === 'bell' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>}
                {service.icon === 'camera' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 00-2 2z" /></svg>}
              </div>
              <h3 class="font-display font-bold text-lg text-navy">{service.title}</h3>
              <span class="text-sm font-semibold text-blue group-hover:text-gold-dark transition-colors mt-auto pt-2">Read More &rarr;</span>
            </Card>
          </a>
        ))}
      </div>
      <div class="text-center mt-4">
        <Button href="/services" variant="outline">View All Security Services</Button>
      </div>
    </div>
  </section>

  <!-- Local FAQs -->
  <section class="section bg-white border-t border-border">
    <div class="container max-w-4xl flex flex-col gap-8">
      <div class="text-center">
        <h2 class="font-display font-bold text-3xl text-navy">Frequently Asked Questions ({area.name})</h2>
      </div>
      
      <div class="flex flex-col gap-4">
        {faqs.map((faq, index) => (
          <div class="border border-border rounded-md overflow-hidden bg-light transition-all duration-200">
            <button
              class="w-full text-left px-6 py-4 font-display font-bold text-navy hover:text-gold flex justify-between items-center bg-white cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-gold"
              aria-expanded="false"
              aria-controls={`faq-answer-${index}`}
            >
              <span>{faq.q}</span>
              <svg class="w-5 h-5 text-steel transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div
              id={`faq-answer-${index}`}
              class="hidden px-6 py-4 text-sm text-steel-dark leading-relaxed bg-light border-t border-border"
              role="region"
            >
              <p>{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-navy py-16 text-white text-center">
    <div class="container max-w-3xl flex flex-col items-center gap-6">
      <h2 class="font-display font-bold text-3xl md:text-4xl">Secure Your {area.name} Premises Today</h2>
      <p class="text-steel-light text-lg">Contact our regional operations team for immediate deployment or to arrange a comprehensive risk assessment.</p>
      <div class="flex flex-wrap justify-center gap-4 mt-4">
        <Button href="/contact" variant="primary" size="lg">Contact Us Online</Button>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const accordions = document.querySelectorAll('[aria-expanded]');
  accordions.forEach((btn) => {
    btn.addEventListener('click', () => {
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      const targetId = btn.getAttribute('aria-controls');
      const target = document.getElementById(targetId || '');
      const arrowIcon = btn.querySelector('svg');

      accordions.forEach((otherBtn) => {
        if (otherBtn !== btn) {
          otherBtn.setAttribute('aria-expanded', 'false');
          const otherTargetId = otherBtn.getAttribute('aria-controls');
          const otherTarget = document.getElementById(otherTargetId || '');
          if (otherTarget) otherTarget.classList.add('hidden');
          const otherIcon = otherBtn.querySelector('svg');
          if (otherIcon) otherIcon.classList.remove('rotate-180');
        }
      });

      btn.setAttribute('aria-expanded', String(!isExpanded));
      if (target) target.classList.toggle('hidden');
      if (arrowIcon) arrowIcon.classList.toggle('rotate-180');
    });
  });
</script>
