---
import PageLayout from '@layouts/PageLayout.astro';
import ContactForm from '@components/forms/ContactForm.astro';
import Badge from '@components/common/Badge.astro';
import Card from '@components/common/Card.astro';
import { sanityClient } from '@lib/sanity';

const contactQuery = `*[_type == "contactInfo"][0]{
  phone,
  emergencyPhone,
  email,
  addressLine1,
  addressLine2,
  city,
  county,
  postcode
}`;
const contactInfo = await sanityClient.fetch(contactQuery).catch(() => null);

const phoneMain = contactInfo?.phone || '023 8012 3456';
const phoneEmergency = contactInfo?.emergencyPhone || '0800 999 1234';
const emailMain = contactInfo?.email || 'info@sqssecurity.co.uk';

const addressLine1 = '104 Graham Rd';
const addressLine2 = '';
const city = 'Southampton';
const county = 'Hampshire';
const postcode = 'SO14 0AZ';
---

<PageLayout 
  title="Contact SQS Security | 24/7 Security Operations UK"
  description="Get in touch with SQS Security for professional manned guarding, mobile patrols, and rapid alarm response services across the UK."
>
  <!-- Hero Section -->
  <section class="bg-navy-dark py-24 md:py-32 text-white relative overflow-hidden">
    <!-- Modern background elements -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-0 left-[20%] w-[500px] h-[500px] bg-gold-dark/20 rounded-full blur-[120px] opacity-60"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[600px] h-[600px] bg-blue-600/20 rounded-full blur-[150px] opacity-50"></div>
      <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.2)_1px,transparent_1px)] bg-[size:24px_24px]"></div>
    </div>

    <div class="container relative z-10 flex flex-col items-center text-center gap-6 max-w-4xl animate-fade-in-up">
      <Badge variant="gold" class="text-sm md:text-base px-4 md:px-5 py-1.5 font-bold uppercase tracking-widest shadow-[0_0_15px_rgba(212,175,55,0.4)]">Get in Touch</Badge>
      <h1 class="font-display font-black text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-tight">
        <span class="text-white">Contact Our</span> <br/>
        <span class="text-gradient-gold">Security Experts</span>
      </h1>
      <p class="text-lg md:text-xl text-steel-light/90 leading-relaxed max-w-2xl mt-2 font-medium">
        Whether you need an urgent emergency response or a comprehensive security assessment for your business, our operations team is ready to assist 24/7.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="section bg-light relative z-20 -mt-10">
    <div class="container grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
      
      <!-- Contact Information Sidebar -->
      <div class="lg:col-span-5 flex flex-col gap-6">
        
        <div class="mb-2">
          <h2 class="font-display font-black text-4xl text-navy mb-2">Reach Out <span class="text-gold">Directly</span></h2>
          <p class="text-steel-dark text-base">Feel free to reach out to our head office for any security inquiries.</p>
        </div>

        <div class="flex flex-col gap-5">
          <!-- General Office -->
          <div class="group bg-white rounded-2xl p-6 shadow-md hover:shadow-xl transition-all duration-300 border border-border hover:border-gold transform hover:-translate-y-1 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gold/5 rounded-bl-full -z-10 transition-transform group-hover:scale-110"></div>
            <div class="flex items-center gap-5">
              <div class="w-14 h-14 bg-gold/10 text-gold-dark rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
              </div>
              <div class="flex flex-col">
                <span class="text-xs uppercase font-bold text-steel tracking-wider mb-1">Head Office</span>
                <a href={`tel:${phoneMain.replace(/\s+/g, '')}`} class="font-display font-black text-2xl text-navy hover:text-gold transition-colors">{phoneMain}</a>
              </div>
            </div>
          </div>

          <!-- Email -->
          <div class="group bg-white rounded-2xl p-6 shadow-md hover:shadow-xl transition-all duration-300 border border-border hover:border-blue-500 transform hover:-translate-y-1 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/5 rounded-bl-full -z-10 transition-transform group-hover:scale-110"></div>
            <div class="flex items-center gap-5">
              <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div class="flex flex-col">
                <span class="text-xs uppercase font-bold text-steel tracking-wider mb-1">General Enquiries</span>
                <a href={`mailto:${emailMain}`} class="font-bold text-lg text-navy hover:text-blue-600 transition-colors break-all">{emailMain}</a>
              </div>
            </div>
          </div>

          <!-- Address -->
          <div class="bg-gradient-to-br from-navy to-navy-dark text-white rounded-2xl p-8 shadow-[0_20px_40px_rgba(11,31,58,0.2)] mt-2 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-40 h-40 bg-gold/10 rounded-bl-full"></div>
            <div class="relative z-10 flex flex-col gap-4">
              <h3 class="font-display font-black text-2xl text-gold">HQ Address</h3>
              <address class="not-italic text-steel-light leading-relaxed text-base">
                <span class="font-bold text-white">SQS Security Service</span><br/>
                {addressLine1}{addressLine2 ? `, ${addressLine2}` : ''}<br/>
                {city}, {county}<br/>
                {postcode}
              </address>
              <div class="mt-4 pt-5 border-t border-white/10 flex flex-wrap gap-3 text-xs font-bold text-white">
                <span class="px-3 py-1.5 bg-white/10 backdrop-blur-sm rounded-md border border-white/10 shadow-sm">SIA-Licensed Security Services</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form Component Wrapper -->
      <div class="lg:col-span-7 flex flex-col h-full">
        <!-- Colorful Gradient Wrapper -->
        <div class="h-full rounded-[2.1rem] bg-gradient-to-br from-gold via-blue-400 to-navy p-[3px] shadow-[0_20px_50px_rgba(11,31,58,0.15)] group hover:shadow-[0_30px_60px_rgba(212,175,55,0.2)] transition-shadow duration-500">
          <div class="bg-white rounded-[2rem] p-8 md:p-12 h-full flex flex-col">
            <div class="mb-10 text-center lg:text-left">
              <h2 class="font-display font-black text-3xl md:text-4xl text-navy mb-4">Send us a message</h2>
              <p class="text-steel-dark text-lg">We aim to respond to all web enquiries within <span class="font-bold text-navy">one business hour</span>.</p>
            </div>
            
            <ContactForm />
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Google Map Embed -->
  <section class="h-[500px] w-full relative group">
    <!-- Top shadow gradient to blend with content above -->
    <div class="absolute top-0 left-0 w-full h-12 bg-gradient-to-b from-light to-transparent z-10 pointer-events-none"></div>
    <iframe 
      src="https://maps.google.com/maps?q=104%20Graham%20Rd,%20Southampton%20SO14%200AZ&t=&z=15&ie=UTF8&iwloc=&output=embed" 
      width="100%" 
      height="100%" 
      style="border:0;" 
      allowfullscreen="" 
      loading="lazy" 
      referrerpolicy="no-referrer-when-downgrade"
      class="absolute inset-0 transition-opacity duration-500"
      title="SQS Security Office Location"
    ></iframe>
    <!-- Interactive overlay that disappears on hover so map is usable, but looks nice before interaction -->
    <div class="absolute inset-0 bg-navy/5 group-hover:bg-transparent transition-colors duration-500 pointer-events-none"></div>
  </section>
</PageLayout>
