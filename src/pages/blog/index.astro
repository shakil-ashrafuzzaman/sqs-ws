---
import PageLayout from '@layouts/PageLayout.astro';
import Card from '@components/common/Card.astro';
import Badge from '@components/common/Badge.astro';
import { sanityClient, urlFor } from '@lib/sanity';

// Fetch all blog posts from Sanity CMS
const query = `*[_type == "blogPost"] | order(publishedAt desc) {
  title,
  "slug": slug.current,
  "type": _type,
  excerpt,
  "category": categories[0]->title,
  publishedAt,
  featuredImage,
  author->{name}
}`;
const fetchedPosts = await sanityClient.fetch(query).catch(() => []);

// Fetch Case Studies from Sanity CMS
const caseStudyQuery = `*[_type == "caseStudy"] | order(_createdAt desc) {
  title,
  "slug": slug.current,
  "type": _type,
  "excerpt": challenge,
  "category": "Case Study",
  "publishedAt": _createdAt,
  "featuredImage": mainImage,
  "author": {"name": client}
}`;
const fetchedCaseStudies = await sanityClient.fetch(caseStudyQuery).catch(() => []);

const fallbackBlogs = [
  {
    slug: 'case-study-construction-site-southampton',
    type: 'caseStudy',
    title: 'Securing a £50M Commercial Development in Southampton',
    excerpt: 'The client faced continuous theft of high-value materials. We deployed 24/7 manned guarding, mobile CCTV towers, and access control.',
    category: 'Case Study',
    publishedAt: new Date().toISOString(),
    featuredImageFallback: 'https://images.unsplash.com/photo-1541888001648-4389025e6db4?w=800&auto=format&fit=crop&q=80',
    author: { name: 'BuildTrust Construction' }
  },
  {
    slug: 'case-study-logistics-hub-cctv',
    type: 'caseStudy',
    title: 'Upgrading Perimeter Security for a National Logistics Hub',
    excerpt: 'Frequent unauthorized access attempts during night shifts. SQS installed long-range thermal CCTV and initiated rapid response mobile patrols.',
    category: 'Case Study',
    publishedAt: new Date(Date.now() - 86400000 * 10).toISOString(),
    featuredImageFallback: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=800&auto=format&fit=crop&q=80',
    author: { name: 'Global Logistics Network' }
  },
  {
    slug: 'importance-of-sia-approved-contractors',
    type: 'blogPost',
    title: 'The Importance of SIA Approved Contractors',
    excerpt: 'Why choosing an SIA Approved Contractor is critical for ensuring high-quality, legally compliant security services for your business.',
    category: 'Compliance',
    publishedAt: new Date(Date.now() - 86400000 * 1).toISOString(),
    featuredImageFallback: 'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=800&auto=format&fit=crop&q=80',
    author: { name: 'SQS Security Expert' }
  },
  {
    slug: '5-reasons-you-need-waking-watch',
    type: 'blogPost',
    title: '5 Reasons Your Property Needs a Waking Watch',
    excerpt: 'Discover why a waking watch is an essential fire safety measure for residential and commercial buildings awaiting cladding remediation or fire system upgrades.',
    category: 'Fire Safety',
    publishedAt: new Date(Date.now() - 86400000 * 5).toISOString(),
    featuredImageFallback: 'https://images.unsplash.com/photo-1541888001648-4389025e6db4?w=800&auto=format&fit=crop&q=80',
    author: { name: 'SQS Operations Team' }
  },
  {
    slug: 'benefits-of-mobile-security-patrols',
    type: 'blogPost',
    title: 'The Benefits of Mobile Security Patrols',
    excerpt: 'Explore how mobile security patrols provide a cost-effective, highly visible deterrent against crime and unauthorized access for large commercial sites.',
    category: 'Security Solutions',
    publishedAt: new Date(Date.now() - 86400000 * 12).toISOString(),
    featuredImageFallback: 'https://images.unsplash.com/photo-1618371690240-e0d46eead4b8?w=800&auto=format&fit=crop&q=80',
    author: { name: 'SQS Mobile Unit' }
  },
  {
    slug: 'cost-to-hire-a-security-guard-uk',
    type: 'blogPost',
    title: 'How Much Does It Cost to Hire a Security Guard in the UK?',
    excerpt: 'Understanding the pricing models and factors that influence the cost of hiring professional, SIA-licensed security guards for your business.',
    category: 'Security Advice',
    publishedAt: new Date(Date.now() - 86400000 * 15).toISOString(),
    featuredImageFallback: 'https://images.unsplash.com/photo-1526304640581-d334cdbbf45e?w=800&auto=format&fit=crop&q=80',
    author: { name: 'SQS Commercial Team' }
  },
  {
    slug: 'duties-and-responsibilities-of-a-security-guard',
    type: 'blogPost',
    title: 'What Are the Key Duties of a Professional Security Guard?',
    excerpt: 'A detailed look into the daily responsibilities, from access control to emergency response, that define a professional security officer.',
    category: 'Security Solutions',
    publishedAt: new Date(Date.now() - 86400000 * 20).toISOString(),
    featuredImageFallback: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=800&auto=format&fit=crop&q=80',
    author: { name: 'SQS Training Team' }
  },
  {
    slug: 'signs-your-business-needs-security',
    type: 'blogPost',
    title: '5 Signs Your Business Needs Professional Security',
    excerpt: 'Is your business at risk? Learn the top indicators that it is time to invest in professional manned guarding or mobile patrols.',
    category: 'Business Protection',
    publishedAt: new Date(Date.now() - 86400000 * 25).toISOString(),
    featuredImageFallback: 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=800&auto=format&fit=crop&q=80',
    author: { name: 'SQS Risk Assessment' }
  },
  {
    slug: 'how-to-hire-event-security',
    type: 'blogPost',
    title: 'The Ultimate Guide to Hiring Event Security Guards',
    excerpt: 'Planning an event? Learn the essential steps for assessing risks, determining guard ratios, and hiring the right event security team.',
    category: 'Event Security',
    publishedAt: new Date(Date.now() - 86400000 * 30).toISOString(),
    featuredImageFallback: 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=800&auto=format&fit=crop&q=80',
    author: { name: 'SQS Events Division' }
  },
  {
    slug: 'cctv-monitoring-vs-manned-guarding',
    type: 'blogPost',
    title: 'CCTV Monitoring vs. Manned Guarding: Which is Best?',
    excerpt: 'Comparing the benefits of electronic surveillance systems with the physical presence of professional security guards.',
    category: 'Security Solutions',
    publishedAt: new Date(Date.now() - 86400000 * 35).toISOString(),
    featuredImageFallback: 'https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=800&auto=format&fit=crop&q=80',
    author: { name: 'SQS Technology Integration' }
  }
];

const posts = [...(fetchedPosts || []), ...(fetchedCaseStudies || []), ...fallbackBlogs].sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());

// Extract unique categories for the filter buttons
const categories = [...new Set(posts.map((post: any) => post.category).filter(Boolean))];
---

<PageLayout 
  title="Security Insights & Blog | SQS Security"
  description="Stay updated with the latest security industry news, compliance updates, and expert insights from SQS Security."
>
  <!-- Hero Section -->
  <section class="bg-navy-dark py-20 md:py-28 text-white relative overflow-hidden">
    <!-- Animated background gradients -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] bg-gold-dark/20 rounded-full blur-[120px] opacity-60 animate-pulse"></div>
      <div class="absolute bottom-[-20%] left-[-10%] w-[600px] h-[600px] bg-blue-500/20 rounded-full blur-[150px] opacity-40"></div>
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0IiBoZWlnaHQ9IjQiPjxyZWN0IHdpZHRoPSI0IiBoZWlnaHQ9IjQiIGZpbGw9IiNmZmYiIGZpbGwtb3BhY2l0eT0iMC4wNSIvPjwvc3ZnPg==')] opacity-30"></div>
    </div>

    <div class="container relative z-10 text-center max-w-4xl flex flex-col items-center gap-6 animate-fade-in-up">
      <Badge variant="gold" class="text-sm md:text-base px-4 md:px-5 py-1.5 font-bold uppercase tracking-widest shadow-[0_0_15px_rgba(212,175,55,0.4)]">News & Insights</Badge>
      <h1 class="font-display font-black text-5xl md:text-6xl lg:text-7xl leading-tight drop-shadow-lg">
        <span class="text-white">SQS Security</span> <br/>
        <span class="text-gradient-gold">Intelligence Hub</span>
      </h1>
      <p class="text-lg md:text-xl text-steel-light/90 max-w-2xl font-medium leading-relaxed">
        Stay ahead of the curve with expert analysis, compliance updates, and practical security advice tailored for UK businesses.
      </p>
    </div>
  </section>

  <section class="section bg-light min-h-[60vh] relative z-20 -mt-8">
    <div class="container flex flex-col gap-12">
      
      <!-- Filters and Search (Floating Bar) -->
      <div class="bg-white/80 backdrop-blur-xl p-4 md:p-6 rounded-2xl shadow-[0_15px_40px_rgba(11,31,58,0.08)] border border-white flex flex-col xl:flex-row gap-6 items-center justify-between mx-auto w-full max-w-[1400px]">
        <!-- Categories Filter -->
        <div class="flex flex-wrap items-center justify-center gap-3 w-full xl:w-auto" id="category-filters">
          <button class="filter-btn active px-6 py-2.5 rounded-full text-sm font-bold bg-navy text-white shadow-md transition-all duration-300 transform hover:-translate-y-0.5" data-category="all">
            All Insights
          </button>
          {categories.map((cat) => (
            <button class="filter-btn px-6 py-2.5 rounded-full text-sm font-bold bg-light text-steel-dark hover:bg-gold/10 hover:text-navy hover:shadow-sm border border-border transition-all duration-300 transform hover:-translate-y-0.5" data-category={cat}>
              {cat}
            </button>
          ))}
        </div>

        <!-- Search Bar -->
        <div class="relative w-full xl:w-96 shrink-0 group">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg class="w-5 h-5 text-steel group-focus-within:text-gold transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <input 
            type="text" 
            id="blog-search" 
            placeholder="Search articles, guides, case studies..." 
            class="w-full pl-12 pr-5 py-3.5 rounded-xl bg-white border-2 border-border focus:outline-none focus:border-gold focus:ring-4 focus:ring-gold/10 transition-all duration-300 text-sm font-medium text-navy placeholder-steel"
          />
        </div>
      </div>

      <!-- Blog Grid -->
      <div id="blog-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-[1400px] mx-auto w-full">
        {posts.map((post) => (
          <article class="blog-card flex h-full group" data-title={post.title.toLowerCase()} data-category={post.category}>
            <a href={`/blog/${post.slug}`} class="flex flex-col w-full bg-white rounded-[24px] shadow-lg hover:shadow-[0_20px_40px_rgba(11,31,58,0.12)] transition-all duration-500 border border-border overflow-hidden relative transform hover:-translate-y-2">
              
              <!-- Image Container -->
              <div class="h-56 relative overflow-hidden bg-navy-dark">
                <!-- Absolute Category Badge overlapping the image -->
                <div class="absolute top-4 left-4 z-20">
                  <span class="inline-block px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider bg-white/90 backdrop-blur-md text-navy shadow-lg border border-white/50">
                    {post.category || 'Updates'}
                  </span>
                </div>
                
                {post.featuredImage?.asset ? (
                  <img src={urlFor(post.featuredImage).width(800).height(500).url()} alt={post.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-90 group-hover:opacity-100" />
                ) : post.featuredImageFallback ? (
                  <img src={post.featuredImageFallback} alt={post.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-90 group-hover:opacity-100" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-navy relative">
                    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(212,175,55,0.15)_0%,transparent_70%)]"></div>
                    <svg class="w-16 h-16 text-white/10 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                    </svg>
                  </div>
                )}
                <!-- Gradient Overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-60"></div>
              </div>
              
              <!-- Content -->
              <div class="p-8 flex flex-col flex-grow relative bg-white z-10">
                <div class="flex items-center gap-4 text-xs font-bold text-steel mb-4 uppercase tracking-widest">
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    {new Date(post.publishedAt || new Date()).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                  </span>
                  <span class="w-1 h-1 rounded-full bg-light"></span>
                  <span class="flex items-center gap-1 text-gold-dark">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    5 min read
                  </span>
                </div>
                
                <h2 class="font-display font-black text-2xl text-navy group-hover:text-gold-dark transition-colors duration-300 leading-snug mb-4">
                  {post.title}
                </h2>
                
                <p class="text-steel-dark text-base flex-grow line-clamp-3 leading-relaxed">
                  {post.excerpt}
                </p>
                
                <!-- Footer area inside card -->
                <div class="mt-8 pt-6 border-t border-light flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-navy to-navy-light text-white flex items-center justify-center font-black text-sm uppercase shadow-sm">
                      {(post.author?.name || 'S').charAt(0)}
                    </div>
                    <span class="text-sm font-bold text-navy truncate max-w-[120px]">{post.author?.name || 'SQS Security'}</span>
                  </div>
                  
                  <div class="w-10 h-10 rounded-full bg-light group-hover:bg-gold flex items-center justify-center transition-colors duration-300 shadow-sm group-hover:shadow-md shrink-0">
                    <svg class="w-5 h-5 text-navy transform group-hover:translate-x-0.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                  </div>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <!-- No Results Message -->
      <div id="no-results" class="hidden text-center py-12 flex-col gap-4 items-center">
        <svg class="w-12 h-12 text-steel-light mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <h3 class="font-display font-bold text-xl text-navy">No articles found</h3>
        <p class="text-steel-dark">Try adjusting your search terms or category filters.</p>
      </div>

    </div>
  </section>
</PageLayout>

<script>
  // Client-side search and filter functionality
  const searchInput = document.getElementById('blog-search') as HTMLInputElement;
  const filterBtns = document.querySelectorAll('.filter-btn');
  const blogCards = document.querySelectorAll('.blog-card');
  const noResults = document.getElementById('no-results');

  let currentCategory = 'all';
  let searchTerm = '';

  function filterPosts() {
    let hasVisibleCards = false;

    blogCards.forEach((card) => {
      const title = card.getAttribute('data-title') || '';
      const category = card.getAttribute('data-category') || '';
      
      const matchesSearch = title.includes(searchTerm);
      const matchesCategory = currentCategory === 'all' || category === currentCategory;

      if (matchesSearch && matchesCategory) {
        card.classList.remove('hidden');
        hasVisibleCards = true;
      } else {
        card.classList.add('hidden');
      }
    });

    if (noResults) {
      if (!hasVisibleCards) {
        noResults.classList.remove('hidden');
        noResults.classList.add('flex');
      } else {
        noResults.classList.add('hidden');
        noResults.classList.remove('flex');
      }
    }
  }

  // Search Listener
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      searchTerm = (e.target as HTMLInputElement).value.toLowerCase();
      filterPosts();
    });
  }

  // Category Filter Listener
  filterBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      // Update active button styling
      filterBtns.forEach(b => {
        b.classList.remove('bg-navy', 'text-white');
        b.classList.add('bg-light', 'text-steel-dark');
      });
      const target = e.currentTarget as HTMLElement;
      target.classList.remove('bg-light', 'text-steel-dark');
      target.classList.add('bg-navy', 'text-white');

      currentCategory = target.getAttribute('data-category') || 'all';
      filterPosts();
    });
  });
</script>
